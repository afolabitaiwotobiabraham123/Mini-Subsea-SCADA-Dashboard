    {
        "id": "45e0431150023ab1",
        "type": "function",
        "z": "f0a9a0b52d4b05ee",
        "name": "MANIFOLD FUNCTION",
        "func": "let w1 = global.get(\"W1\") || {flow:0};\nlet w2 = global.get(\"W2\") || {flow:0};\nlet w3 = global.get(\"W3\") || {flow:0};\n\nlet totalFlow = w1.flow + w2.flow + w3.flow;\n\nmsg.payload = {\n    totalFlow: totalFlow,\n    status: \"MANIFOLD ACTIVE\"\n}\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
