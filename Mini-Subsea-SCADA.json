    {
        "id": "19672eaf7074eef1",
        "type": "function",
        "z": "f0a9a0b52d4b05ee",
        "name": "ALARM FUNCTION",
        "func": "if (msg.payload.totalFlow < 2000) {\n    msg.payload.alarm = \"CRITICAL LOW PRODUCTION 🔴\";\n} else if (msg.payload.totalFlow < 4000) {\n    msg.payload.alarm = \"WARNING 🟠\";\n} else {\n    msg.payload.alarm = \"NORMAL 🟢\";\n}\n\nreturn msg;",
